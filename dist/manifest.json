{
  "manifest_version": 3,
  "name": "Croma",
  "version": "0.1.0",
  "description": "AI dev tools inside your browser",
  "permissions": [
    "storage",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "service-worker-loader.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "js": [
        "assets/content.tsx-loader-BbSvrxgq.js"
      ],
      "matches": [
        "<all_urls>"
      ],
      "run_at": "document_idle",
      "all_frames": true
    }
  ],
  "action": {
    "default_popup": "src/popup/popup.html"
  },
  "devtools_page": "src/devtools/devtools.html",
  "web_accessible_resources": [
    {
      "matches": [
        "<all_urls>"
      ],
      "resources": [
        "src/devtools/panel.html",
        "assets/hooks.module-CwlBfBTs.js",
        "assets/content.tsx--mAZiiWv.js"
      ],
      "use_dynamic_url": false
    }
  ]
}
